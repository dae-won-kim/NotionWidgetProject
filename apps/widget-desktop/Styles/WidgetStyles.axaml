<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:theme="clr-namespace:WidgetDesktop.Styles">

  <Style Selector="Window">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="FontFamily"  Value="{x:Static theme:WidgetTheme.FontFamilyPrimary}"/>
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{x:Static theme:WidgetTheme.TextPrimaryBrush}"/>
    <Setter Property="FontSize"   Value="{x:Static theme:WidgetTheme.FontSizeBody}"/>
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize"   Value="{x:Static theme:WidgetTheme.FontSizeTitle}"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>

  <!-- Status button — always dark text (badge bg is a light Notion pastel) -->
  <Style Selector="Button.status">
    <Setter Property="Width"                      Value="28"/>
    <Setter Property="Height"                     Value="28"/>
    <Setter Property="VerticalAlignment"          Value="Center"/>
    <Setter Property="CornerRadius"               Value="6"/>
    <Setter Property="FontSize"                   Value="14"/>
    <Setter Property="FontWeight"                 Value="SemiBold"/>
    <Setter Property="Foreground"                 Value="#2D2D2D"/>
    <Setter Property="BorderThickness"            Value="0"/>
    <Setter Property="Focusable"                  Value="False"/>
    <Setter Property="Cursor"                     Value="Hand"/>
    <Setter Property="Padding"                    Value="0"/>
    <Setter Property="Opacity"                    Value="1"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment"   Value="Center"/>
  </Style>

  <Style Selector="Button.status.hover">
    <Setter Property="Opacity" Value="{x:Static theme:WidgetTheme.StatusHoverOpacity}"/>
  </Style>

  <Style Selector="Button.status.pressed">
    <Setter Property="Opacity" Value="{x:Static theme:WidgetTheme.StatusPressedOpacity}"/>
  </Style>

</Styles>
